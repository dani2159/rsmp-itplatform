# Copy ke .env sebelum `docker compose up`:  cp .env.docker.example .env
# Ganti semua nilai di bawah -- jangan pakai default ini di production.

DB_ROOT_PASS=changeme-root
DB_NAME=rsmpitdb
DB_USER=rsmpitadmin
DB_PASS=changeme-db
SESSION_SECRET=changeme-session-secret
AGENT_TOKEN=changeme-agent-token

RS_NAME=RSMP-IT
SERVER_IP=localhost
WEB_PORT=8080

# Password admin awal -- dipakai sekali oleh `make seed-admin`. Kalau kosong,
# script generate password random dan cetak ke output.
ADMIN_PASSWORD=
